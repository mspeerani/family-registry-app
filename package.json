{
  "name": "family-registry-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "audit:project": "powershell -ExecutionPolicy Bypass -File .\\scripts\\project_audit.ps1 -Strict",
    "build": "npm run build --workspaces",
    "check": "npm run typecheck --workspaces && npm run test --workspaces && npm run build --workspaces && npm run audit:project",
    "db:migrate": "npm --workspace apps/api run db:migrate",
    "db:seed": "npm --workspace apps/api run db:seed",
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "smoke:local": "powershell -ExecutionPolicy Bypass -File .\\scripts\\release_smoke.ps1",
    "stress:api": "npm --workspace apps/api run stress",
    "test": "npm run test --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
